DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_TIME_ZONE=UTC

# Preferred: a single PostgreSQL URL
# DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/tech

# Or use separate variables instead of DATABASE_URL
POSTGRES_DB=tech
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
# POSTGRES_SSLMODE=require
